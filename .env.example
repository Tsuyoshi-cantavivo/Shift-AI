# ===========================================================
# ShiftAI 環境設定ファイル
# このファイルを .env としてコピーし、値を書き換えて使用してください。
# Railway にデプロイする場合は、これらの値を Railway ダッシュボードの
# Variables タブに設定してください。
# -----------------------------------------------------------

# Flask シークレット（セッション署名等に使用）。本番はランダムな長文字列に。
FLASK_SECRET=change-this-to-random-secret

# -----------------------------------------------------------
# データベース設定
# -----------------------------------------------------------
# local: ローカル SQLite ファイル（開発用）
# d1: Cloudflare D1 REST API（本番用）
DB_MODE=local
DB_PATH=shift.db

# -----------------------------------------------------------
# D1設定（DB_MODE=d1 の場合に必要）
# Cloudflare ダッシュボード で取得:
#   CF_ACCOUNT_ID: アカウントID（ダッシュボード右側に表示）
#   CF_D1_DATABASE_ID: D1データベースのID
#   CF_D1_API_TOKEN: D1へのアクセス権があるAPIトークン
# -----------------------------------------------------------
# DB_MODE=d1
# CF_ACCOUNT_ID=あなたのアカウントID
# CF_D1_DATABASE_ID=あなたのD1データベースID
# CF_D1_API_TOKEN=あなたのAPIトークン

# -----------------------------------------------------------
# AI (LLM) API 設定
# OpenAI互換の Chat Completions API に対応。
# LLM_API_KEY に空文字以外を設定するとAI機能が有効化され、
# 未設定時はルールベースのフォールバックで動作します。
# -----------------------------------------------------------
LLM_API_KEY=
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini

# -----------------------------------------------------------
# デバッグ（本番では必ず 0）
# -----------------------------------------------------------
FLASK_DEBUG=0
